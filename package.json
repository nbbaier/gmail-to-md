{
  "name": "gmail-to-md",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome MV3 extension that exports the selected Gmail message as a Markdown document.",
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/chrome": "^0.0.287",
    "typescript": "^5.7.2",
    "ultracite": "7.8.3",
    "@types/bun": "latest"
  },
  "scripts": {
    "build": "bun run build.ts",
    "dev": "bun run build.ts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "ultracite check",
    "format": "ultracite fix",
    "test": "bun test",
    "check": "ultracite check && tsc --noEmit && bun test",
    "fix": "ultracite fix"
  }
}
